# =============================================================================
# Variables de entorno — Cluster OSFATUN
# =============================================================================
# Copiar este archivo a .env y completar TODOS los valores antes de desplegar.
# El archivo .env NO debe commitearse al repositorio (está en .gitignore).
#
# Uso con envsubst:
#   set -a && source .env && set +a
#   envsubst < <archivo>.yaml | kubectl apply -f -
#
# Ejemplo para desplegar todo el stack:
#   set -a && source .env && set +a
#   envsubst < cloudnativepg.yaml  | kubectl apply -f -
#   envsubst < keycloak.yaml       | kubectl apply -f -
#   envsubst < secret_keycloak.yaml | kubectl apply -f -
#   envsubst < osfatun-backend.yaml | kubectl apply -f -
# =============================================================================


# -----------------------------------------------------------------------------
# BASE DE DATOS (CloudNativePG)
# Compartido entre: cloudnativepg.yaml, keycloak.yaml, osfatun-backend.yaml
# -----------------------------------------------------------------------------

# Password del usuario 'app' (owner de las bases de datos de aplicación).
# Este valor DEBE SER IDÉNTICO en cloudnativepg.yaml, keycloak.yaml y osfatun-backend.yaml.
DB_APP_PASSWORD=

# Password del superusuario 'postgres'.
DB_SUPERUSER_PASSWORD=


# -----------------------------------------------------------------------------
# KEYCLOAK
# -----------------------------------------------------------------------------

# Password del usuario administrador de Keycloak (consola web).
KEYCLOAK_ADMIN_PASSWORD=

# Client Secret del client OIDC 'pomerium' creado en Keycloak.
# Se obtiene en Keycloak → Realm osfatun → Clients → pomerium → Credentials.
KEYCLOAK_OIDC_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# OSFATUN BACKEND — Registry de imágenes
# -----------------------------------------------------------------------------

# Imagen completa del backend incluyendo registry, nombre y tag.
# Ejemplo: registry.gitlab.com/org/osfatun-backend:v1.0.0
BACKEND_IMAGE=

# Contenido del archivo ~/.docker/config.json codificado en base64.
# Generarlo con:
#   kubectl create secret docker-registry gitlab-registry \
#     --docker-server=registry.gitlab.com \
#     --docker-username=<USUARIO> \
#     --docker-password=<TOKEN> \
#     --dry-run=client -o jsonpath='{.data.\.dockerconfigjson}'
DOCKER_CONFIG_BASE64=


# -----------------------------------------------------------------------------
# OSFATUN BACKEND — Django
# -----------------------------------------------------------------------------

# Clave secreta de Django. Generar con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=


# -----------------------------------------------------------------------------
# OSFATUN BACKEND — Email (SMTP)
# -----------------------------------------------------------------------------

EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=


# -----------------------------------------------------------------------------
# OSFATUN BACKEND — Sentry (monitoreo de errores)
# -----------------------------------------------------------------------------

# DSN del proyecto en Sentry. Dejar vacío para deshabilitar.
SENTRY_DSN=


# -----------------------------------------------------------------------------
# OSFATUN BACKEND — WhatsApp Business API
# -----------------------------------------------------------------------------

WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=


# -----------------------------------------------------------------------------
# OSFATUN BACKEND — Sistema externo (sincronización)
# -----------------------------------------------------------------------------

EXTERNAL_SYSTEM_API_URL=
EXTERNAL_SYSTEM_API_KEY=
EXTERNAL_SYSTEM_USERNAME=
EXTERNAL_SYSTEM_PASSWORD=


# -----------------------------------------------------------------------------
# OSFATUN BACKEND — Webhooks
# -----------------------------------------------------------------------------

WEBHOOK_API_URL=
WEBHOOK_API_TOKEN=
