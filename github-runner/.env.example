# =============================================================================
# Configuración del GitHub Actions Self-Hosted Runner
# =============================================================================
# Copiar este archivo a .env y completar los valores
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub Configuration (REQUERIDO)
# -----------------------------------------------------------------------------
# URL del repositorio o de la organización
# Para repositorio: https://github.com/usuario/repositorio
# Para organización: https://github.com/organizacion
GITHUB_URL=https://github.com/tu-usuario/osfatun

# Token de registro del runner
# Obtener desde: Settings → Actions → Runners → New self-hosted runner
# IMPORTANTE: Este token expira, regenerar si es necesario
GITHUB_TOKEN=AXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# Runner Configuration
# -----------------------------------------------------------------------------
# Nombre único del runner (aparece en GitHub)
RUNNER_NAME=osfatun-runner

# Labels para identificar el runner en workflows
# Separados por coma, sin espacios
RUNNER_LABELS=docker,linux,self-hosted,osfatun,prod

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------
# GID del grupo docker en el host
# Obtener con: getent group docker | cut -d: -f3
DOCKER_GID=999
